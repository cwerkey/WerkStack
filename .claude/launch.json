{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend-v2",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=frontend-v2"],
      "port": 5174,
      "autoPort": true
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=frontend"],
      "port": 5173
    },
    {
      "name": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=backend"],
      "port": 3001,
      "env": {
        "DATABASE_URL": "postgres://werkstack:werkstack_dev@localhost:5433/werkstack"
      }
    }
  ]
}
